# Copy to .env and fill in your local Azure values. .env is git-ignored.
# Never commit real project/resource/subscription/tenant identifiers.

# HTTP port for the local server.
PORT=3000

# Foundry AI Services / OpenAI account and its resource group (for direct deployment data).
AZURE_FOUNDRY_PROJECT_NAME=
AZURE_RESOURCE_GROUP=

# Catalog region resolution order: AZURE_FOUNDRY_REGION -> AZURE_REGION -> AZURE_LOCATION -> default.
AZURE_FOUNDRY_REGION=
AZURE_REGION=
AZURE_LOCATION=

# Optional explicit account name overrides for direct deployment lookups.
AZURE_AI_SERVICES_ACCOUNT_NAME=
AZURE_OPENAI_ACCOUNT_NAME=

# Comma-separated regions to scan for regional availability.
# If unset, a curated common-AI-region list is scanned and results are marked "sampled".
AZURE_LOCATIONS=eastus,eastus2,swedencentral

# Comma-separated Azure ML registries (reserved for future registry enrichment).
AZURE_ML_REGISTRIES=azureml,azureml-meta,azureml-mistral
